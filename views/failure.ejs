    <!-- ── HELP CARD HTML ─────────────────────────────────────── -->
    <div class="help-card">
      <!-- head -->
      <div class="help-card-head">
        <div class="help-card-title">
          🔍 How to get an available seat faster
        </div>
        <div class="help-card-sub">
          Pick the right search below based on your current WL position
        </div>
      </div>

      <!-- rank section -->
      <div class="help-section-label">
        Ranked by WL position — try in this order
      </div>

      <div class="rank-rows">
        <!-- RAC -->
        <div class="rank-row success">
          <div class="rank-number success">1</div>
          <div class="rank-content">
            <div class="rank-top">
              <span class="rank-title success"
                >RAC</span
              >
              <!-- <span class="rank-badge success"></span> -->
            </div>
            <p class="rank-dsearch direct route firstesc success">
              1st search priority position to these Train while searching...
            </p>
          </div>
        </div>

        <!-- WL < 10 -->
        <div class="rank-row success-dim">
          <div class="rank-number success-dim">2</div>
          <div class="rank-content">
            <div class="rank-top">
              <span class="rank-title success-dim">WL &lt; 10 </span>
              <!-- <span class="rank-badge success-dim">Direct → Adjust</span> -->
            </div>
            <p class="rank-desc success-dim">
              2nd search priority position to these Train while searching...
            </p>
          </div>
        </div>

        <!-- WL 10-25 -->
        <div class="rank-row warning">
          <div class="rank-number warning">3</div>
          <div class="rank-content">
            <div class="rank-top">
              <span class="rank-title warning">WL 10–25</span>
              <!-- <span class="rank-badge warning">Split Journey</span> -->
            </div>
            <p class="rank-desc warning">
              3nd search priority position to these Train while searching...
            </p>
          </div>
        </div>

        <!-- WL > 25 -->
        <div class="rank-row danger">
          <div class="rank-number danger">4</div>
          <div class="rank-content">
            <div class="rank-top">
              <span class="rank-title danger"
                >WL &gt; 25</span
              >
              <!-- <span class="rank-badge danger">Extended Search</span> -->
            </div>
            <p class="rank-desc danger">
              4nd search priority position to these Train while searching...
            </p>
          </div>
        </div>
      </div>

